<script>
const fmt = n => 'Rp ' + Math.round(n).toLocaleString('id-ID');
const fmtS = n => {
  const abs = Math.abs(n);
  const sign = n < 0 ? '-' : '';
  if(abs >= 1000000) return sign + 'Rp ' + (abs/1000000).toFixed(1) + 'jt';
  if(abs >= 1000) return sign + 'Rp ' + (abs/1000).toFixed(0) + 'rb';
  return fmt(n);
};

let expenses = JSON.parse(localStorage.getItem('cb_pl_expenses') || '[]');
let revenueData = {gross:0,diskon:0,komisi:0,orders:0,monthly:{}};
let mainChart = null;
let fbConfig = {
  apiKey: "AIzaSyDYl792JM-8MLSqn_ismOecFbtA1tjH5-g",
  authDomain: "cerdas-bersama-b914e.firebaseapp.com",
  projectId: "cerdas-bersama-b914e",
  appId: "1:742743770113:web:8109c06b77a37b5207ec00"
};
let authToken = null;

const DEMO = [
  {hargaBase:34900,diskon:17450,komisi:2618,status:'paid',createdAt:{seconds:1740000000}},
  {hargaBase:34900,diskon:0,komisi:2618,status:'paid',createdAt:{seconds:1740200000}},
  {hargaBase:69900,diskon:34950,komisi:5243,status:'paid',createdAt:{seconds:1741000000}},
  {hargaBase:34900,diskon:17450,komisi:2618,status:'paid',createdAt:{seconds:1742000000}},
  {hargaBase:99900,diskon:0,komisi:7493,status:'paid',createdAt:{seconds:1742500000}},
  {hargaBase:34900,diskon:0,komisi:0,status:'paid',createdAt:{seconds:1743000000}},
  {hargaBase:69900,diskon:34950,komisi:5243,status:'paid',createdAt:{seconds:1744000000}},
  {hargaBase:34900,diskon:17450,komisi:2618,status:'paid',createdAt:{seconds:1744500000}},
  {hargaBase:99900,diskon:49950,komisi:7493,status:'paid',createdAt:{seconds:1745000000}},
  {hargaBase:34900,diskon:0,komisi:2618,status:'paid',createdAt:{seconds:1745500000}},
  {hargaBase:69900,diskon:0,komisi:5243,status:'paid',createdAt:{seconds:1746000000}},
  {hargaBase:34900,diskon:17450,komisi:2618,status:'paid',createdAt:{seconds:1746800000}},
];

const $ = id => document.getElementById(id);
const show = id => $(id).style.display = 'block';
const hide = id => $(id).style.display = 'none';

async function doLogin() {
  const email = $('login-email').value.trim();
  const pass = $('login-pass').value;
  const errEl = $('login-error');
  errEl.style.display = 'none';
  if(!email || !pass) { errEl.textContent = 'Isi email dan password.'; errEl.style.display = 'block'; return; }
  try {
    const res = await fetch(`https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=${fbConfig.apiKey}`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({email, password: pass, returnSecureToken: true})
    });
    const data = await res.json();
    if(data.error) { errEl.textContent = 'Login gagal: ' + (data.error.message || 'Cek email/password'); errEl.style.display = 'block'; return; }
    authToken = data.idToken;
    hide('step-login');
    showDashboard(true, email);
    await loadFromFirestore();
  } catch(e) {
    errEl.textContent = 'Error: ' + e.message; errEl.style.display = 'block';
  }
}

function showDashboard(loggedIn, email) {
  show('step-dashboard');
  show('header-right');
  if(loggedIn) {
    $('conn-badge').className = 'badge badge-ok';
    $('conn-badge').innerHTML = '<i class="ti ti-wifi"></i> Terhubung';
    $('user-info').textContent = email;
    $('user-info').style.display = 'inline-flex';
    $('btn-logout').style.display = 'inline-flex';
  }
  renderExpenses();
}

async function loadFromFirestore() {
  try {
    const url = `https://firestore.googleapis.com/v1/projects/${fbConfig.projectId}/databases/(default)/documents:runQuery`;
    const body = {structuredQuery:{from:[{collectionId:'orders'}],where:{fieldFilter:{field:{fieldPath:'status'},op:'EQUAL',value:{stringValue:'paid'}}}}};
    const res = await fetch(url, {
      method: 'POST',
      headers: {'Content-Type':'application/json','Authorization':'Bearer '+authToken},
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if(!Array.isArray(data)) { console.error('Firestore error', data); return; }
    const orders = data.filter(r => r.document).map(r => {
      const f = r.document.fields || {};
      const ts = f.createdAt?.timestampValue;
      return {
        hargaBase: parseFloat(f.hargaBase?.integerValue || f.hargaBase?.doubleValue || 0),
        diskon: parseFloat(f.diskon?.integerValue || f.diskon?.doubleValue || 0),
        komisi: parseFloat(f.komisi?.integerValue || f.komisi?.doubleValue || 0),
        status: f.status?.stringValue || '',
        createdAt: {seconds: ts ? Math.floor(new Date(ts).getTime()/1000) : 0}
      };
    });
    processOrders(orders);
  } catch(e) { console.error('Load error', e); }
}

function doLogout() {
  authToken = null;
  hide('step-dashboard'); hide('header-right');
  show('step-login');
  $('login-pass').value = '';
}

function refreshData() {
  if(authToken) loadFromFirestore();
  else processOrders(DEMO);
}

function processOrders(orders) {
  const from = $('dateFrom').value;
  const to = $('dateTo').value;
  const fromMs = new Date(from+'-01').getTime()/1000;
  const toDate = new Date(to+'-01'); toDate.setMonth(toDate.getMonth()+1);
  const toMs = toDate.getTime()/1000;
  let gross=0, diskon=0, komisi=0, count=0;
  const monthly = {};
  orders.filter(o => o.status === 'paid').forEach(o => {
    const ts = o.createdAt?.seconds || 0;
    if(ts < fromMs || ts >= toMs) return;
    const d = new Date(ts*1000);
    const key = d.getFullYear()+'-'+(d.getMonth()+1).toString().padStart(2,'0');
    if(!monthly[key]) monthly[key] = {gross:0,diskon:0,komisi:0};
    gross += o.hargaBase||0; diskon += o.diskon||0; komisi += o.komisi||0; count++;
    monthly[key].gross += o.hargaBase||0; monthly[key].diskon += o.diskon||0; monthly[key].komisi += o.komisi||0;
  });
  revenueData = {gross, diskon, komisi, orders:count, monthly};
  updateUI();
}

function getExpTotals() {
  const c = {hosting:0,marketing:0,gaji:0,payment:0,ops:0,device:0,infra:0,capex_other:0};
  expenses.forEach(e => { if(c[e.cat] !== undefined) c[e.cat] += e.amt; });
  return c;
}

function updateUI() {
  const {gross, diskon, komisi, orders, monthly} = revenueData;
  const netrev = gross - diskon;
  const gp = netrev - komisi;
  const c = getExpTotals();
  const opex = c.hosting + c.marketing + c.gaji + c.payment + c.ops;
  const capex = c.device + c.infra + c.capex_other;
  const ebitda = gp - opex;
  const net = ebitda - capex;
  const margin = netrev > 0 ? (net/netrev*100).toFixed(1) : 0;

  $('m-revenue').textContent = fmt(gross);
  $('m-diskon').textContent = fmt(diskon);
  $('m-netrev').textContent = fmt(netrev);
  $('m-opex').textContent = fmt(opex + capex + komisi);
  $('m-orders').textContent = orders + ' transaksi';
  const npEl = $('m-netprofit'); npEl.textContent = fmt(net);
  npEl.className = 'metric-val ' + (net >= 0 ? 'green' : 'red');
  $('m-margin').textContent = 'Margin: ' + margin + '%';

  $('d-grossrev').textContent = fmt(gross);
  $('d-diskon').textContent = '(' + fmt(diskon) + ')';
  $('d-netrev').textContent = fmt(netrev);
  $('d-cogs').textContent = '(' + fmt(komisi) + ')';
  $('d-grossprofit').textContent = fmt(gp);
  $('d-opex-hosting').textContent = '(' + fmt(c.hosting) + ')';
  $('d-opex-marketing').textContent = '(' + fmt(c.marketing) + ')';
  $('d-opex-gaji').textContent = '(' + fmt(c.gaji) + ')';
  $('d-opex-payment').textContent = '(' + fmt(c.payment) + ')';
  $('d-opex-ops').textContent = '(' + fmt(c.ops) + ')';
  $('d-ebitda').textContent = fmt(ebitda);
  $('d-capex-device').textContent = '(' + fmt(c.device) + ')';
  $('d-capex-infra').textContent = '(' + fmt(c.infra) + ')';
  $('d-capex-other').textContent = '(' + fmt(c.capex_other) + ')';
  const dnp = $('d-netprofit'); dnp.textContent = fmt(net);
  dnp.className = net >= 0 ? '' : 'negative';

  updateChart(monthly, opex, capex);
}

function updateChart(monthly, opex, capex) {
  const from = $('dateFrom').value, to = $('dateTo').value;
  const labels = [], revArr = [], expArr = [], profArr = [];
  let cur = new Date(from+'-01'), end = new Date(to+'-01');
  let tm = 0; let tmp = new Date(from+'-01');
  while(tmp <= end) { tm++; tmp.setMonth(tmp.getMonth()+1); }
  tm = tm || 1;
  while(cur <= end) {
    const key = cur.getFullYear()+'-'+(cur.getMonth()+1).toString().padStart(2,'0');
    labels.push(key);
    const m = monthly[key] || {gross:0,diskon:0,komisi:0};
    const mRev = m.gross - m.diskon;
    const mExp = m.komisi + (opex + capex)/tm;
    revArr.push(Math.round(mRev));
    expArr.push(Math.round(mExp));
    profArr.push(Math.round(mRev - mExp));
    cur.setMonth(cur.getMonth()+1);
  }
  if(mainChart) mainChart.destroy();
  mainChart = new Chart($('mainChart'), {
    type: 'bar',
    data: {labels, datasets: [
      {label:'Net Revenue', data:revArr, backgroundColor:'rgba(29,158,117,0.75)', borderRadius:4},
      {label:'Pengeluaran', data:expArr, backgroundColor:'rgba(226,75,74,0.65)', borderRadius:4},
      {type:'line', label:'Net Profit', data:profArr, borderColor:'#378ADD', backgroundColor:'rgba(55,138,221,0.08)', borderWidth:2, pointRadius:4, tension:0.3, fill:true}
    ]},
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {legend: {display: false}},
      scales: {
        y: {ticks: {callback: v => fmtS(v)}, grid: {color:'rgba(128,128,128,0.08)'}},
        x: {grid: {display: false}, ticks: {autoSkip: false, maxRotation: 0}}
      }
    }
  });
}

const catLabels = {hosting:'Server / Hosting', marketing:'Marketing / Iklan', gaji:'Gaji / Honorarium', payment:'Payment Gateway', ops:'Operasional lain', device:'Perangkat / Komputer', infra:'Server Infrastruktur', capex_other:'CapEx lainnya'};

function addExpense() {
  const cat = $('exp-cat').value;
  const desc = $('exp-desc').value.trim();
  const amt = parseFloat($('exp-amt').value) || 0;
  if(!desc || amt <= 0) { alert('Isi deskripsi dan jumlah terlebih dahulu.'); return; }
  expenses.push({cat, desc, amt, id: Date.now()});
  localStorage.setItem('cb_pl_expenses', JSON.stringify(expenses));
  $('exp-desc').value = ''; $('exp-amt').value = '';
  renderExpenses(); updateUI();
}

function deleteExpense(id) {
  expenses = expenses.filter(e => e.id !== id);
  localStorage.setItem('cb_pl_expenses', JSON.stringify(expenses));
  renderExpenses(); updateUI();
}

function renderExpenses() {
  const list = $('exp-list');
  if(!expenses.length) { list.innerHTML = '<div class="exp-empty">Belum ada pengeluaran. Tambahkan di atas.</div>'; return; }
  list.innerHTML = expenses.map(e => `
    <div class="exp-item">
      <span class="exp-cat-badge">${catLabels[e.cat]||e.cat}</span>
      <span class="exp-desc">${e.desc}</span>
      <span class="exp-amt">${fmt(e.amt)}</span>
      <button class="exp-del" onclick="deleteExpense(${e.id})" aria-label="Hapus"><i class="ti ti-trash"></i></button>
    </div>`).join('');
}

function switchTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  ['overview','detail','expenses'].forEach(t => {
    $(('tab-'+t)).style.display = t === tab ? 'block' : 'none';
  });
}

