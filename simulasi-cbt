<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Simulasi CBT — CerdasBersama</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #faf8f5; --white: #fff; --border: #e8e4dc; --text: #1a1714;
      --muted: #7a7168; --muted2: #b0a89c; --red: #C0392B; --red2: #a93226;
      --gold: #e8970a; --gold-bg: #fff8e6; --green: #1a7a4a; --green-bg: #edfaf3;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06); --shadow: 0 4px 16px rgba(0,0,0,0.08);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    
    nav { background: var(--white); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 24px; height: 56px; position: sticky; top: 0; z-index: 100; box-shadow: var(--shadow-sm); }
    .nav-logo { font-weight: 800; font-size: 17px; color: var(--red); }
    .nav-logo span { color: var(--text); }
    .nav-back { display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: var(--muted); text-decoration: none; }

    #loadingScreen { position: fixed; inset: 0; background: var(--bg); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; z-index: 200; }
    .spinner { width: 34px; height: 34px; border: 3px solid var(--border); border-top-color: var(--red); border-radius: 50%; animation: spin 0.75s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .cbt-container { display: grid; grid-template-columns: 1fr 300px; gap: 20px; max-width: 1200px; margin: 0 auto; padding: 24px 20px; }
    @media (max-width: 850px) { .cbt-container { grid-template-columns: 1fr; } }

    .soal-wrapper { display: flex; flex-direction: column; gap: 16px; }
    .soal-card { background: var(--white); border: 1px solid var(--border); border-radius: 20px; padding: 28px; box-shadow: var(--shadow-sm); min-height: 300px; }
    .soal-meta { display: flex; gap: 8px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; justify-content: space-between; }
    .meta-kiri { display: flex; gap: 8px; }
    .tag { font-size: 11px; font-weight: 700; color: var(--red); background: #fff5f5; border: 1px solid #fdd; padding: 4px 12px; border-radius: 50px; text-transform: uppercase; }
    .tag.tipe { color: var(--gold); background: var(--gold-bg); border-color: #f5d06a; }
    .timer-box { font-size: 14px; font-weight: 800; color: var(--white); background: var(--red); padding: 6px 14px; border-radius: 8px; letter-spacing: 1px; box-shadow: 0 2px 8px rgba(192,57,43,0.3); }
    
    .soal-text { font-size: 16px; font-weight: 700; line-height: 1.6; margin-bottom: 24px; white-space: pre-line; }

    .opsi-list { display: flex; flex-direction: column; gap: 10px; }
    .opsi-item { display: flex; align-items: center; gap: 14px; padding: 14px 18px; border: 1.5px solid var(--border); border-radius: 12px; cursor: pointer; transition: all 0.15s; background: var(--white); }
    .opsi-item:hover { border-color: var(--red); background: #fff8f8; }
    .opsi-item.selected { border-color: var(--red); background: #fff5f5; font-weight: 700; }
    .opsi-key { width: 32px; height: 32px; border-radius: 50%; background: var(--surface2); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; color: var(--muted); }
    .opsi-item.selected .opsi-key { background: var(--red); color: #fff; border-color: var(--red); }
    
    .input-isian { width: 100%; max-width: 400px; border: 2px solid var(--border); border-radius: 12px; padding: 14px; font-size: 16px; font-weight: 700; font-family: inherit; outline: none; transition: border-color 0.2s; }
    .input-isian:focus { border-color: var(--red); }

    .tabel-majemuk { width: 100%; border-collapse: collapse; margin-top: 10px; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
    .tabel-majemuk th, .tabel-majemuk td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); }
    .tabel-majemuk th { background: #f5f3ef; font-size: 12px; font-weight: 800; color: var(--muted); text-transform: uppercase; }
    .tabel-majemuk td { font-size: 14px; font-weight: 600; }
    .radio-cell { text-align: center; width: 80px; }
    .radio-cell input { cursor: pointer; width: 18px; height: 18px; accent-color: var(--red); }

    .soal-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
    .btn-cbt { padding: 12px 24px; border-radius: 50px; border: none; font-family: inherit; font-size: 14px; font-weight: 800; cursor: pointer; transition: all 0.18s; }
    .btn-cbt.primary { background: var(--red); color: #fff; box-shadow: 0 4px 14px rgba(192,57,43,0.25); }
    .btn-cbt.primary:hover { background: var(--red2); }
    .btn-cbt.secondary { background: #f5f3ef; color: var(--text); border: 1.5px solid var(--border); }
    .btn-cbt.secondary:hover { background: var(--border); }
    .btn-cbt:disabled { opacity: 0.3; cursor: not-allowed; }

    .sidebar-card { background: var(--white); border: 1px solid var(--border); border-radius: 20px; padding: 20px; box-shadow: var(--shadow-sm); position: sticky; top: 80px; }
    .sidebar-title { font-size: 13px; font-weight: 800; text-transform: uppercase; color: var(--muted); letter-spacing: 0.5px; margin-bottom: 4px; display: flex; justify-content: space-between;}
    .sidebar-sub { font-size: 11px; font-weight: 600; color: var(--gold); margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid var(--border);}
    .nomor-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; max-height: 350px; overflow-y: auto; padding-right: 4px; margin-bottom: 20px;}
    .nomor-btn { aspect-ratio: 1; border: 1.5px solid var(--border); background: var(--white); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; color: var(--text); cursor: pointer; transition: all 0.15s; }
    .nomor-btn:hover { border-color: var(--red); color: var(--red); }
    .nomor-btn.current { border-color: var(--text); background: var(--text); color: #fff; }
    .nomor-btn.filled { background: #fff5f5; border-color: var(--red); color: var(--red); }
    
    .btn-finish { width: 100%; padding: 12px; background: var(--text); color: #fff; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; }
    .btn-finish:hover { background: #333; }

    #finishScreen { display: none; text-align: center; padding: 60px 20px; }
    .finish-icon { font-size: 64px; margin-bottom: 20px; }
    .finish-title { font-size: 24px; font-weight: 900; margin-bottom: 10px; }
    .finish-sub { font-size: 14px; color: var(--muted); margin-bottom: 30px; line-height: 1.6; max-width: 400px; margin-inline: auto; }
  </style>
</head>
<body>

<nav>
  <div class="nav-logo">Cerdas<span>Bersama</span> <span style="font-size:12px; color:var(--muted)">· CBT Engine</span></div>
  <a href="/dashboard.html" class="nav-back" id="btnKeluar">← Keluar Ujian</a>
</nav>

<div id="loadingScreen"><div class="spinner"></div><p style="font-size:14px; font-weight:500; color:var(--muted)">Mempersiapkan soal & timer…</p></div>

<div class="cbt-container" id="examScreen" style="display:none;">
  <div class="soal-wrapper">
    <div class="soal-card">
      <div class="soal-meta">
        <div class="meta-kiri">
          <span class="tag" id="tagMapel">—</span>
          <span class="tag tipe" id="tagTipe">—</span>
        </div>
        <div class="timer-box" id="timerDisplay">00:00:00</div>
      </div>
      <div class="soal-text" id="boxPertanyaan">Memuat soal...</div>
      <div id="boxJawaban"></div>
    </div>
    <div class="soal-nav">
      <button class="btn-cbt secondary" id="btnPrev">← Sebelumnya</button>
      <button class="btn-cbt primary" id="btnNext">Selanjutnya →</button>
    </div>
  </div>

  <div class="sidebar-card">
    <div class="sidebar-title"><span>Navigasi Soal</span> <span id="blokIndicator">Blok 1</span></div>
    <div class="sidebar-sub" id="blokSubtesName">Nama Subtes</div>
    <div class="nomor-grid" id="gridNomor"></div>
    <button class="btn-finish" id="btnSubmitBlok">Selesaikan Blok Ini</button>
  </div>
</div>

<div id="finishScreen">
  <div class="finish-icon">✅</div>
  <div class="finish-title">Ujian Selesai!</div>
  <div class="finish-sub">Jawaban kamu sudah terkirim ke server dan sedang masuk antrean proses Batch IRT. Hasil dan pemeringkatan akan muncul di Dashboard saat pengumuman.</div>
  <a href="/dashboard.html" class="btn-cbt primary" style="text-decoration:none;">Kembali ke Dashboard</a>
</div>

<script type="module">
  import { auth, db } from "./firebase-config.js";
  import { onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
  import { collection, getDocs, query, where, addDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

  const $ = id => document.getElementById(id);
  
  let targetSegmen = '';
  let jawabanUser = {};
  
  let blokGroup = {};
  let urutanBlokKeys = [];
  let currentBlokIndex = 0;
  
  let soalAktifDiBlok = [];
  let currentIdx = 0;
  
  let timerInterval;
  let sisaDetik = 0;
  let isSubmitting = false;

  // ================= EVENT LISTENERS (bukan inline onclick) =================
  $('btnPrev').addEventListener('click', () => lompatSoal(currentIdx - 1));
  $('btnNext').addEventListener('click', () => lompatSoal(currentIdx + 1));
  $('btnSubmitBlok').addEventListener('click', () => akhiriBlokIni(false));

  // ================= AUTH & INIT =================
  onAuthStateChanged(auth, async user => {
    if (!user) { window.location.href = '/register.html'; return; }
    
    const params = new URLSearchParams(window.location.search);
    targetSegmen = params.get('segmen') || 'CBT CPNS';

    try {
      const q = query(collection(db, 'soal'), where('segmen', '==', targetSegmen));
      const snap = await getDocs(q);
      const rawSoal = snap.docs.map(d => ({ id: d.id, ...d.data() }));

      if (rawSoal.length === 0) {
        alert("Belum ada soal tersedia di segmen ini.");
        window.location.href = '/dashboard.html';
        return;
      }

      rawSoal.forEach(s => {
        const urutan = s.urutanSubtes || 1;
        if (!blokGroup[urutan]) blokGroup[urutan] = [];
        blokGroup[urutan].push(s);
      });

      urutanBlokKeys = Object.keys(blokGroup).map(Number).sort((a, b) => a - b);
      
      $('loadingScreen').style.display = 'none';
      $('examScreen').style.display = 'grid';
      
      history.pushState(null, null, location.href);
      window.onpopstate = () => history.go(1);

      mulaiBlok(0);

    } catch (err) {
      alert("Gagal memuat soal: " + err.message);
    }
  });

  // ================= 1. MANAJEMEN BLOK & TIMER =================
  function mulaiBlok(index) {
    currentBlokIndex = index;
    const keyBlok = urutanBlokKeys[currentBlokIndex];
    soalAktifDiBlok = blokGroup[keyBlok];
    currentIdx = 0;

    $('blokIndicator').textContent = `Blok ${currentBlokIndex + 1} / ${urutanBlokKeys.length}`;
    $('blokSubtesName').textContent = soalAktifDiBlok[0].kategori || 'Ujian';
    
    if (currentBlokIndex === urutanBlokKeys.length - 1) {
      $('btnSubmitBlok').textContent = 'Selesaikan Ujian';
      $('btnSubmitBlok').style.background = 'var(--red)';
    } else {
      $('btnSubmitBlok').textContent = 'Selesaikan Blok Ini';
      $('btnSubmitBlok').style.background = 'var(--text)';
    }

    const menit = soalAktifDiBlok[0].durasiMenit || 30;
    sisaDetik = menit * 60;
    
    renderGridNomor();
    tampilkanSoal();
    jalankanTimer();
  }

  function jalankanTimer() {
    clearInterval(timerInterval);
    updateDisplayTimer();
    
    timerInterval = setInterval(() => {
      sisaDetik--;
      updateDisplayTimer();
      
      if (sisaDetik <= 0) {
        clearInterval(timerInterval);
        alert('Waktu untuk bagian ini telah habis!');
        akhiriBlokIni(true);
      }
    }, 1000);
  }

  function updateDisplayTimer() {
    const jam = Math.floor(sisaDetik / 3600);
    const mnt = Math.floor((sisaDetik % 3600) / 60);
    const dtk = sisaDetik % 60;
    const pad = n => n.toString().padStart(2, '0');
    $('timerDisplay').textContent = jam > 0 ? `${pad(jam)}:${pad(mnt)}:${pad(dtk)}` : `${pad(mnt)}:${pad(dtk)}`;
    $('timerDisplay').style.background = sisaDetik < 60 ? '#8a0a0a' : 'var(--red)';
  }

  async function akhiriBlokIni(isForce = false) {
    if (isSubmitting) return;
    
    if (!isForce) {
      const sisaSoal = soalAktifDiBlok.filter(s => jawabanUser[s.id] === undefined).length;
      const pesan = sisaSoal > 0
        ? `Masih ada ${sisaSoal} soal kosong di blok ini. Yakin ingin mengakhiri sekarang? (Anda tidak bisa kembali lagi ke blok ini)`
        : `Yakin ingin mengakhiri blok ini sekarang?`;
      if (!confirm(pesan)) return;
    }

    clearInterval(timerInterval);

    if (currentBlokIndex + 1 >= urutanBlokKeys.length) {
      await submitKeFirestore();
    } else {
      mulaiBlok(currentBlokIndex + 1);
    }
  }

  // ================= 2. SUBMIT KE FIRESTORE =================
  async function submitKeFirestore() {
    if (isSubmitting) return;
    isSubmitting = true;
    
    $('loadingScreen').style.display = 'flex';
    $('loadingScreen').querySelector('p').textContent = 'Menyimpan jawaban, mohon jangan tutup halaman...';
    $('examScreen').style.display = 'none';

    try {
      await addDoc(collection(db, 'jawaban_peserta'), {
        uid: auth.currentUser.uid,
        email: auth.currentUser.email,
        segmen: targetSegmen,
        waktuSubmit: serverTimestamp(),
        jawaban: jawabanUser
      });
      
      $('loadingScreen').style.display = 'none';
      $('finishScreen').style.display = 'block';
      $('btnKeluar').style.display = 'none';
    } catch (err) {
      alert("Terjadi kesalahan saat menyimpan data: " + err.message);
      isSubmitting = false;
      $('loadingScreen').style.display = 'none';
      $('examScreen').style.display = 'grid';
    }
  }

  // ================= 3. RENDER UI =================
  function renderGridNomor() {
    const grid = $('gridNomor');
    grid.innerHTML = '';
    soalAktifDiBlok.forEach((soal, idx) => {
      const btn = document.createElement('button');
      btn.className = 'nomor-btn';
      btn.id = `num_btn_${idx}`;
      btn.textContent = idx + 1;
      if (jawabanUser[soal.id] !== undefined) btn.classList.add('filled');
      if (idx === currentIdx) btn.classList.add('current');
      btn.addEventListener('click', () => lompatSoal(idx));
      grid.appendChild(btn);
    });
  }

  function lompatSoal(targetIdx) {
    if (targetIdx < 0 || targetIdx >= soalAktifDiBlok.length) return;
    currentIdx = targetIdx;
    
    document.querySelectorAll('.nomor-btn').forEach(b => b.classList.remove('current'));
    const currentBtn = $(`num_btn_${currentIdx}`);
    if (currentBtn) currentBtn.classList.add('current');

    tampilkanSoal();
  }

  function tampilkanSoal() {
    const soal = soalAktifDiBlok[currentIdx];
    const isLastSoal = currentIdx + 1 === soalAktifDiBlok.length;
    const isLastBlok = currentBlokIndex + 1 === urutanBlokKeys.length;
    
    $('tagMapel').textContent = soal.kategori || 'Ujian';
    $('tagTipe').textContent = String(soal.tipeSoal).replace('_', ' ').toUpperCase();
    $('boxPertanyaan').textContent = `${currentIdx + 1}. ${soal.pertanyaan}`;

    $('btnPrev').disabled = currentIdx === 0;

    // Reset btnNext listener setiap render soal
    const btnNext = $('btnNext');
    const newBtnNext = btnNext.cloneNode(true);
    btnNext.parentNode.replaceChild(newBtnNext, btnNext);

    if (isLastSoal) {
      newBtnNext.textContent = isLastBlok ? 'Selesai Ujian' : 'Lanjut Blok Berikutnya';
      newBtnNext.addEventListener('click', () => akhiriBlokIni(false));
    } else {
      newBtnNext.textContent = 'Selanjutnya →';
      newBtnNext.addEventListener('click', () => lompatSoal(currentIdx + 1));
    }

    const boxJawaban = $('boxJawaban');
    boxJawaban.innerHTML = '';

    const tipe = soal.tipeSoal || 'pg_biasa';
    const savedAnswer = jawabanUser[soal.id];

    if (tipe === 'pg_biasa' || tipe === 'tkp') {
      const listDiv = document.createElement('div');
      listDiv.className = 'opsi-list';
      
      ['A','B','C','D','E'].forEach(key => {
        if (!soal.opsi || !soal.opsi[key]) return;
        const item = document.createElement('div');
        item.className = 'opsi-item' + (savedAnswer === key ? ' selected' : '');
        item.innerHTML = `<div class="opsi-key">${key}</div><div class="opsi-text">${soal.opsi[key]}</div>`;
        item.addEventListener('click', () => {
          document.querySelectorAll('.opsi-item').forEach(i => i.classList.remove('selected'));
          item.classList.add('selected');
          simpanJawaban(soal.id, key);
        });
        listDiv.appendChild(item);
      });
      boxJawaban.appendChild(listDiv);
    }
    else if (tipe === 'isian') {
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'input-isian';
      input.placeholder = 'Ketik jawaban Anda di sini...';
      input.value = savedAnswer || '';
      input.addEventListener('input', () => simpanJawaban(soal.id, input.value.trim()));
      boxJawaban.appendChild(input);
    }
    else if (tipe === 'majemuk') {
      if (!soal.pernyataanMajemuk || !soal.pernyataanMajemuk.length) return;
      
      const table = document.createElement('table');
      table.className = 'tabel-majemuk';
      table.innerHTML = `<thead><tr><th>Pernyataan</th><th class="radio-cell">Benar</th><th class="radio-cell">Salah</th></tr></thead><tbody></tbody>`;
      
      const tbody = table.querySelector('tbody');
      // Deep copy supaya tidak mutate object yang disimpan
      const currentMajemukAns = savedAnswer ? { ...savedAnswer } : {};

      soal.pernyataanMajemuk.forEach((p, pIdx) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${p.teks}</td>
          <td class="radio-cell"><input type="radio" name="mjm_${currentIdx}_${pIdx}" value="Benar" ${currentMajemukAns[pIdx] === 'Benar' ? 'checked' : ''}/></td>
          <td class="radio-cell"><input type="radio" name="mjm_${currentIdx}_${pIdx}" value="Salah" ${currentMajemukAns[pIdx] === 'Salah' ? 'checked' : ''}/></td>
        `;
        tr.querySelectorAll('input').forEach(radio => {
          radio.addEventListener('change', () => {
            currentMajemukAns[pIdx] = radio.value;
            simpanJawaban(soal.id, { ...currentMajemukAns });
          });
        });
        tbody.appendChild(tr);
      });
      boxJawaban.appendChild(table);
    }
  }

  function simpanJawaban(soalId, value) {
    const isEmpty = value === '' || (typeof value === 'object' && Object.keys(value).length === 0);
    if (isEmpty) {
      delete jawabanUser[soalId];
      $(`num_btn_${currentIdx}`).classList.remove('filled');
    } else {
      jawabanUser[soalId] = value;
      $(`num_btn_${currentIdx}`).classList.add('filled');
    }
  }
</script>
</body>
</html>
